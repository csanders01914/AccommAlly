generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

/// Tenant represents a workspace/organization in the WaaS platform
model Tenant {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  domain                String?                @unique
  status                TenantStatus           @default(ACTIVE)
  planId                String?
  subscriptionPlan      SubscriptionPlan?      @relation(fields: [planId], references: [id])
  plan                  String                 @default("FREE")
  settings              Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accommodations        Accommodation[]
  annotationComments    AnnotationComment[]
  auditLogs             AuditLog[]
  bugReports            BugReport[]
  callRequests          CallRequest[]
  cases                 Case[]
  claimFamilies         ClaimFamily[]
  claimants             Claimant[]
  clients               Client[]
  contacts              Contact[]
  documentTemplates     DocumentTemplate[]
  documents             Document[]
  errorLogs             ErrorLog[]
  identityVerifications IdentityVerification[]
  inboundRules          InboundRule[]
  inventoryItems        InventoryItem[]
  meetings              Meeting[]
  meetingAttendees      MeetingAttendee[]
  messages              Message[]
  messageFolders        MessageFolder[]
  notes                 Note[]
  reminders             Reminder[]
  tasks                 Task[]
  users                 User[]

  @@index([slug])
  @@index([status])
  @@index([planId])
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  code            String   @unique // FREE, STARTER, PRO, ENTERPRISE
  name            String
  maxUsers        Int      @default(5) // -1 for unlimited
  maxActiveClaims Int      @default(10) // -1 for unlimited
  tenants         Tenant[]
}

/// Super-Admin accounts for platform-level management (separate from tenant users)
model SuperAdmin {
  id               String    @id @default(cuid())
  email            String    @unique
  emailHash        String    @unique
  name             String
  passwordHash     String
  active           Boolean   @default(true)
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLogin        DateTime?

  @@index([email])
}

/// User accounts with Role-Based Access Control (RBAC)
model User {
  id                     String            @id @default(cuid())
  tenantId               String
  email                  String
  emailHash              String            @unique
  name                   String
  role                   Role              @default(COORDINATOR)
  active                 Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  username               String?           @unique
  pronouns               String?
  theme                  String            @default("system")
  notifications          Json?
  preferences            Json?
  twoFactorSecret        String?
  twoFactorEnabled       Boolean           @default(false)
  twoFactorRecoveryCodes String[]
  passwordHash           String?
  lastLogin              DateTime?
  loginAttempts          Int               @default(0)
  lockedUntil            DateTime?
  emailSignature         String?
  decidedAccommodations  Accommodation[]   @relation("DecisionMaker")
  annotationComments     AnnotationComment[]
  auditLogs              AuditLog[]
  bugReports             BugReport[]
  createdCases           Case[]            @relation("CaseCreatedBy")
  uploadedDocuments      Document[]
  errorLogs              ErrorLog[]
  inboundRules           InboundRule[]
  inventory              InventoryItem[]
  organizedMeetings      Meeting[]         @relation("MeetingOrganizer")
  meetingAttendances     MeetingAttendee[]
  receivedMessages       Message[]         @relation("ReceivedMessages")
  sentMessages           Message[]         @relation("SentMessages")
  messageFolders         MessageFolder[]
  notes                  Note[]
  reminders              Reminder[]
  assignedTasks          Task[]            @relation("AssignedTo")
  createdTasks           Task[]            @relation("CreatedBy")
  tenant                 Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([role])
}

/// Client accommodation cases with unique Case Numbers
model Case {
  id                    String                 @id @default(cuid())
  tenantId              String
  caseNumber            String                 @unique
  clientName            String
  clientLastName        String?   // Encrypted — last name only, used for portal identity check
  clientEmail           String?
  clientEmailHash       String?
  clientPhone           String?
  clientPhoneHash       String?
  clientBirthdate       DateTime?
  title                 String
  description           String?
  medicalCondition      String?
  category              String?
  program               String?
  venue                 String?
  preferredStartDate    String?
  jobTitle              String?
  jobFamily             String?
  requestDate           DateTime?
  medicalDueDate        DateTime?
  status                CaseStatus             @default(OPEN)
  priority              Int                    @default(2)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  closedAt              DateTime?
  createdById           String
  clientId              String?
  claimantRef           String?
  claimFamilyId         String?
  accommodations        Accommodation[]
  callRequests          CallRequest[]
  claimFamily           ClaimFamily?           @relation(fields: [claimFamilyId], references: [id])
  claimant              Claimant?              @relation(fields: [claimantRef], references: [id])
  client                Client?                @relation(fields: [clientId], references: [id])
  createdBy             User                   @relation("CaseCreatedBy", fields: [createdById], references: [id])
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  contacts              Contact[]
  documents             Document[]
  identityVerifications IdentityVerification[]
  inventory             InventoryItem[]
  meetings              Meeting[]
  messages              Message[]
  notes                 Note[]
  tasks                 Task[]

  @@index([tenantId])
  @@index([caseNumber])
  @@index([clientName])
  @@index([status])
  @@index([createdById])
  @@index([clientId])
  @@index([claimantRef])
  @@index([claimFamilyId])
}

/// Corporate Clients (e.g. TCP)
model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   @unique
  code      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cases     Case[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

/// Claimant - individuals who submit accommodation requests
model Claimant {
  id             String   @id @default(cuid())
  tenantId       String
  claimantNumber String   @unique
  name           String
  nameHash       String
  birthdate      DateTime
  email          String?
  emailHash      String?
  phone          String?
  phoneHash      String?
  pinHash        String?
  passphraseHash String?
  credentialType String   @default("PIN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cases          Case[]
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([nameHash, birthdate])
  @@index([tenantId])
  @@index([claimantNumber])
  @@index([emailHash])
  @@index([phoneHash])
}

/// Claim Family - groups related cases together
model ClaimFamily {
  id        String   @id @default(cuid())
  tenantId  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cases     Case[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

/// Identity Verification - logs verification attempts during phone calls
model IdentityVerification {
  id           String   @id @default(cuid())
  tenantId     String
  caseId       String
  noteId       String?
  verified     Boolean
  attemptedAt  DateTime @default(now())
  verifiedById String
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([caseId])
  @@index([verifiedById])
}

/// Contacts associated with a Case (Address Book)
model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  role      String
  email     String?
  phone     String?
  type      String
  address   String?
  notes     String?
  caseId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([caseId])
  @@index([type])
}

/// Accommodation requests linked to a Case
/// Accommodation requests linked to a Case
model Accommodation {
  id                  String              @id @default(cuid())
  tenantId            String
  accommodationNumber String              @default("001")
  type                AccommodationType
  subtype             String?
  description         String
  status              AccommodationStatus @default(PENDING)
  lifecycleStatus     LifecycleStatus     @default(OPEN)
  lifecycleSubstatus  LifecycleSubstatus  @default(PENDING)
  isLongTerm          Boolean             @default(false)
  startDate           DateTime
  endDate             DateTime?
  estimatedCost       Decimal?            @db.Decimal(10, 2)
  actualCost          Decimal?            @db.Decimal(10, 2)
  reviewDate          DateTime?
  isExternal          Boolean             @default(false)
  decisionDate        DateTime?
  decisionMakerId     String?
  costCode            String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  caseId              String
  case                Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  decisionMaker       User?               @relation("DecisionMaker", fields: [decisionMakerId], references: [id])
  tenant              Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([caseId, accommodationNumber])
  @@index([tenantId])
  @@index([caseId])
  @@index([status])
  @@index([decisionMakerId])
}

/// Tasks for case orchestration with due dates and assignees
model Task {
  id           String       @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     String       @default("MEDIUM")
  category     TaskCategory @default(OTHER)
  dueDate      DateTime
  startTime    DateTime?
  endTime      DateTime?
  color        String       @default("#8b5cf6")
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  caseId       String
  assignedToId String
  createdById  String
  reminders    Reminder[]
  assignedTo   User         @relation("AssignedTo", fields: [assignedToId], references: [id])
  case         Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CreatedBy", fields: [createdById], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@index([category])
  @@index([assignedToId])
  @@index([caseId])
}

/// Threaded, chronological notes attached to Cases
model Note {
  id        String   @id @default(cuid())
  tenantId  String
  content   String
  noteType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  caseId    String
  authorId  String
  parentId  String?
  author    User     @relation(fields: [authorId], references: [id])
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  parent    Note?    @relation("NoteReplies", fields: [parentId], references: [id])
  replies   Note[]   @relation("NoteReplies")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([caseId])
  @@index([authorId])
  @@index([createdAt])
  @@index([noteType])
}

/// Automated audit log tracking "Who changed what and when"
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  action     String
  field      String?
  oldValue   String?
  newValue   String?
  metadata   String?
  timestamp  DateTime @default(now())
  userId     String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

/// Documents attached to Cases with Document Control Numbers
model Document {
  id                    String       @id @default(cuid())
  tenantId              String
  fileName              String
  fileType              String
  fileSize              Int
  fileData              Bytes
  documentControlNumber String       @unique
  category              String       @default("OTHER")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  caseId                String
  uploadedById          String
  annotationComments    AnnotationComment[]
  case                  Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  uploadedBy            User         @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([caseId])
  @@index([documentControlNumber])
  @@index([category])
  @@index([uploadedById])
}

/// Letter templates uploaded by super admins, used to populate message bodies
model DocumentTemplate {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  originalFile     Bytes
  fileType         String   @default("application/vnd.openxmlformats-officedocument.wordprocessingml.document")
  htmlContent      String
  variableMappings Json
  createdByAdminId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum AnnotationCommentType {
  HIGHLIGHT_PDF
  HIGHLIGHT_EMAIL
  DOCUMENT_NOTE
  EMAIL_NOTE
}

/// Unified annotation comments for documents and messages
model AnnotationComment {
  id         String                @id @default(cuid())
  tenantId   String
  tenant     Tenant                @relation(fields: [tenantId], references: [id])

  documentId String?
  document   Document?             @relation(fields: [documentId], references: [id], onDelete: Cascade)

  messageId  String?
  message    Message?              @relation(fields: [messageId], references: [id], onDelete: Cascade)

  parentId   String?
  parent     AnnotationComment?    @relation("Replies", fields: [parentId], references: [id])
  replies    AnnotationComment[]   @relation("Replies")

  type       AnnotationCommentType

  content    String
  deletedAt  DateTime?

  // Highlight color — applies to HIGHLIGHT_PDF and HIGHLIGHT_EMAIL (null for notes)
  color      String?               @default("#FFFF00")

  // PDF highlight geometry fields (null for email highlights and notes)
  pageNumber Int?
  x          Float?
  y          Float?
  width      Float?
  height     Float?

  // Email text selection fields (null for PDF highlights and notes)
  selectedText   String?
  selectionStart Int?
  selectionEnd   Int?

  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([tenantId, documentId])
  @@index([tenantId, messageId])
  @@index([tenantId, createdById])
}

/// Secure internal messaging between users with external email support
model Message {
  id                 String                    @id @default(cuid())
  tenantId           String
  subject            String?
  content            String
  read               Boolean                   @default(false)
  inInbox            Boolean                   @default(true)
  starred            Boolean                   @default(false)
  archived           Boolean                   @default(false)
  deletedBySender    Boolean                   @default(false)
  deletedByRecipient Boolean                   @default(false)
  inTrash            Boolean                   @default(false)
  inJunk             Boolean                   @default(false)
  trashDate          DateTime?
  createdAt          DateTime                  @default(now())
  senderId           String?
  recipientId        String?
  isExternal         Boolean                   @default(false)
  externalEmail      String?
  externalEmailHash  String?
  externalName       String?
  direction          String                    @default("INTERNAL")
  externalMessageId  String?
  caseId             String?
  replyToId          String?
  forwardedFromId    String?
  case               Case?                     @relation(fields: [caseId], references: [id])
  forwardedFrom      Message?                  @relation("MessageForwards", fields: [forwardedFromId], references: [id])
  forwards           Message[]                 @relation("MessageForwards")
  recipient          User?                     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  replyTo            Message?                  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies            Message[]                 @relation("MessageReplies")
  sender             User?                     @relation("SentMessages", fields: [senderId], references: [id])
  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  folderAssignments  MessageFolderAssignment[]
  attachments        MessageAttachment[]
  annotationComments AnnotationComment[]

  @@index([tenantId])
  @@index([senderId])
  @@index([recipientId])
  @@index([read])
  @@index([caseId])
  @@index([starred])
  @@index([archived])
  @@index([isExternal])
  @@index([direction])
}

/// Custom message folders created by users
model MessageFolder {
  id        String                    @id @default(cuid())
  tenantId  String
  name      String
  color     String                    @default("#6366f1")
  icon      String?
  position  Int                       @default(0)
  userId    String
  createdAt DateTime                  @default(now())
  rules     InboundRuleFolder[]
  tenant    Tenant                    @relation(fields: [tenantId], references: [id])
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  MessageFolderAssignment[]

  @@unique([userId, name])
  @@index([tenantId])
  @@index([userId])
}

/// Many-to-many linking messages to folders
model MessageFolderAssignment {
  id        String        @id @default(cuid())
  messageId String
  folderId  String
  createdAt DateTime      @default(now())
  folder    MessageFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  message   Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, folderId])
  @@index([messageId])
  @@index([folderId])
}

/// Inbound message routing rules
model InboundRule {
  id                          String              @id @default(cuid())
  tenantId                    String
  name                        String
  enabled                     Boolean             @default(true)
  priority                    Int                 @default(0)
  senderContains              String?
  senderEquals                String?
  subjectContains             String?
  contentContains             String?
  caseNumberContains          String?
  isExternal                  Boolean?
  hasAttachment               Boolean?
  isHighPriority              Boolean?
  actionKeepInInbox           Boolean             @default(false)
  actionMarkAsRead            Boolean             @default(false)
  actionStar                  Boolean             @default(false)
  actionArchive               Boolean             @default(false)
  actionSendEmailNotification Boolean             @default(false)
  actionSendSMSNotification   Boolean             @default(false)
  userId                      String
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  tenant                      Tenant              @relation(fields: [tenantId], references: [id])
  user                        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetFolders               InboundRuleFolder[]

  @@index([tenantId])
  @@index([userId])
  @@index([enabled])
}

/// Many-to-many linking rules to target folders
model InboundRuleFolder {
  ruleId   String
  folderId String
  folder   MessageFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  rule     InboundRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([ruleId, folderId])
}

/// Call requests/return call tracking
model CallRequest {
  id           String     @id @default(cuid())
  tenantId     String
  name         String
  phoneNumber  String
  reason       String
  urgent       Boolean    @default(false)
  status       String     @default("PENDING")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  scheduledFor DateTime?
  caseId       String
  case         Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  reminders    Reminder[]

  @@index([tenantId])
  @@index([status])
  @@index([urgent])
}

/// Asset Inventory for Assistive Technology
model InventoryItem {
  id                 String          @id @default(cuid())
  tenantId           String
  name               String
  assetTag           String          @unique
  serialNumber       String?
  category           String
  status             InventoryStatus @default(AVAILABLE)
  condition          String          @default("GOOD")
  purchaseDate       DateTime?
  cost               Decimal?        @db.Decimal(10, 2)
  supplier           String?
  assignedToUserId   String?
  assignedToCaseId   String?
  assignedDate       DateTime?
  expectedReturnDate DateTime?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  assignedToCase     Case?           @relation(fields: [assignedToCaseId], references: [id])
  assignedToUser     User?           @relation(fields: [assignedToUserId], references: [id])
  tenant             Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([assignedToUserId])
  @@index([assignedToCaseId])
}

/// Meetings with recurrence support
model Meeting {
  id             String            @id @default(cuid())
  tenantId       String
  title          String
  description    String?
  location       String?
  startTime      DateTime
  endTime        DateTime
  allDay         Boolean           @default(false)
  color          String            @default("#3b82f6")
  type           MeetingType       @default(OTHER)
  recurrenceRule String?
  recurrenceEnd  DateTime?
  parentId       String?
  caseId         String?
  organizerId    String
  externalId     String?
  syncSource     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  case           Case?             @relation(fields: [caseId], references: [id])
  organizer      User              @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  parent         Meeting?          @relation("MeetingRecurrence", fields: [parentId], references: [id])
  instances      Meeting[]         @relation("MeetingRecurrence")
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  attendees      MeetingAttendee[]
  reminders      Reminder[]

  @@index([tenantId])
  @@index([startTime])
  @@index([organizerId])
  @@index([caseId])
}

/// Meeting attendees
model MeetingAttendee {
  id        String  @id @default(cuid())
  tenantId  String
  meetingId String
  userId    String?
  email     String?
  status    String  @default("PENDING")
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  user      User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([meetingId])
  @@index([userId])
}

/// Reminders for meetings, tasks, and calls
model Reminder {
  id          String       @id @default(cuid())
  tenantId    String
  type        String       @default("EMAIL")
  triggerAt   DateTime
  sent        Boolean      @default(false)
  meetingId   String?
  taskId      String?
  callId      String?
  userId      String
  createdAt   DateTime     @default(now())
  callRequest CallRequest? @relation(fields: [callId], references: [id], onDelete: Cascade)
  meeting     Meeting?     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([triggerAt])
  @@index([sent])
  @@index([userId])
}

/// Detailed Error Logs for debugging with Transaction IDs
model ErrorLog {
  id            String   @id @default(cuid())
  tenantId      String?
  transactionId String   @unique
  message       String
  stack         String?
  path          String?
  method        String?
  statusCode    Int      @default(500)
  metadata      Json?
  userId        String?
  timestamp     DateTime @default(now())
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([transactionId])
  @@index([timestamp])
  @@index([userId])
}

/// User-submitted bug reports
model BugReport {
  id            String   @id @default(cuid())
  tenantId      String?
  transactionId String?
  subject       String
  description   String
  reporterName  String
  reporterEmail String?
  reporterPhone String?
  contactMethod String?
  status        String   @default("OPEN")
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([transactionId])
  @@index([status])
  @@index([userId])
}

/// Per-key rate limit counters used for distributed rate limiting across serverless instances
model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum InventoryStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
